# App name shown in page metadata and UI labels.
# Change this to your product or company name.
NEXT_PUBLIC_APP_NAME="IoTrust Console"

# Public base URL of your app.
# Local development usually uses http://localhost:3000
# In production, use your deployed domain such as:
# https://your-project.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js base URL.
# This must match the exact domain where your app runs.
# Local example:
# http://localhost:3000
# Production example:
# https://your-project.vercel.app
AUTH_URL="http://localhost:3000"

# If you deploy through GitHub Actions, also register the same values in:
# GitHub -> Settings -> Secrets and variables -> Actions
# and in:
# Vercel -> Project Settings -> Environment Variables

# Secret used by Auth.js to sign and encrypt session cookies.
# Generate a strong random string.
# Example command:
# openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth Client ID from Google Cloud Console.
# Create OAuth credentials in:
# APIs & Services -> Credentials
GOOGLE_CLIENT_ID=""

# Google OAuth Client Secret from Google Cloud Console.
# Copy the client secret paired with the Client ID above.
GOOGLE_CLIENT_SECRET=""

# Optional Google Drive JSON file ID used as the dashboard data source.
# Upload a JSON file to Google Drive, make it viewable by link,
# and paste only the file ID here.
# Example share link:
# https://drive.google.com/file/d/1AbCdEfGhIjKlMnOpQrStUvWxYz/view?usp=sharing
# Example file ID:
# 1AbCdEfGhIjKlMnOpQrStUvWxYz
GOOGLE_DRIVE_DASHBOARD_FILE_ID=""

# Email domain restriction.
# This project is set to allow only iotrust.kr accounts by default.
# Users must sign in with an email ending in @iotrust.kr
ALLOWED_EMAIL_DOMAIN="iotrust.kr"

# Upstash Redis REST API credentials.
# Create a database at https://console.upstash.com and copy the REST URL and token.
# Dashboard data is stored in Redis under the key: dashboard:content
# Blocked accounts are stored in Redis under the key: auth:blocked
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
